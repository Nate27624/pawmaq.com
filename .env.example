NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MODERATION_MODEL_RUNTIME=ollama
PROFILE_LEDGER_PATH=.context/profile-ledger.json
POST_LEDGER_PATH=.context/post-popularity-ledger.json
MEDIA_INDEX_PATH=.context/media-index.json
MEDIA_STORAGE_DIR=.context/media-uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:3000
PRE_LEDGER_QUEUE_MAX_PENDING=80
PRE_LEDGER_POSTS_PER_MINUTE_PER_IP=90
PRE_LEDGER_MEDIA_UPLOADS_PER_10M_PER_IP=20
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_STORE=memory
AUTH_SESSION_REDIS_PREFIX=pawmaq:session:
GOOGLE_OAUTH_CLIENT_IDS=
RSS_BOTS_ENABLED=true
RSS_BOTS_INTERVAL_MINUTES=15
# 0 = import all available items each run, >0 = cap per feed per run
RSS_BOTS_MAX_ITEMS_PER_FEED_PER_RUN=0
RSS_BOTS_USER_AGENT=pawmaq-rss-bot/1.0 (+https://pawmaq.com)
# Supports either:
# - JSON array
# - line/semicolon format: feedUrl|handle|name|countryCode|countryName|bio
RSS_BOTS_FEEDS=[{"feedUrl":"https://mastodon.social/@TechCrunch.rss","handle":"@techcrunch_rss","name":"TechCrunch RSS","countryCode":"US","countryName":"United States"},{"feedUrl":"https://mastodon.social/tags/news.rss","handle":"@mastodon_news_rss","name":"Mastodon #news","countryCode":"WW","countryName":"Worldwide"}]
TEST_LAB_ENABLED=true
DATABASE_URL=postgresql://pawmaq:pawmaq@postgres:5432/pawmaq
REDIS_URL=
OLLAMA_BASE_URL=http://ollama:11434
VITE_GOOGLE_CLIENT_ID=
VITE_API_BASE_URL=http://localhost:3000
